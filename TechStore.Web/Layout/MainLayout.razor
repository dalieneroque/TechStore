@using TechStore.Web.Services
@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject CarrinhoService Carrinho
@inject AuthService Auth

<nav class="navbar navbar-dark bg-dark shadow sticky-top">
    <div class="container-fluid px-3">

        <!-- LOGO -->
        <a href="/" class="navbar-brand fw-bold">💻 TechStore</a>

        <!-- BUSCA (só desktop) -->
        <div class="d-none d-md-flex flex-grow-1 mx-4" style="max-width:400px">
            <input type="text"
                   class="form-control form-control-sm rounded-pill"
                   placeholder="Buscar produtos..."
                   @bind="termoPesquisa"
                   @bind:event="oninput"
                   @onkeydown="OnKeyDown" />
        </div>

        <!-- MENU DESKTOP (só md+) -->
        <div class="d-none d-md-flex align-items-center gap-3">
            <NavLink href="/" class="text-white text-decoration-none small">
                <i class="bi bi-house"></i> Início
            </NavLink>
            <NavLink href="/produtos" class="text-white text-decoration-none small">
                <i class="bi bi-grid"></i> Produtos
            </NavLink>
            <NavLink href="/carrinho" class="text-white text-decoration-none small position-relative">
                <i class="bi bi-cart"></i> Carrinho
                @if (Auth.IsAuthenticated && Carrinho.QuantidadeTotal > 0)
                {
                    <span class="badge bg-warning text-dark ms-1">
                        @Carrinho.QuantidadeTotal
                    </span>
                }
            </NavLink>

            @if (Auth.IsAuthenticated)
            {
                <NavLink href="/perfil" class="text-white text-decoration-none small">
                    <i class="bi bi-person"></i> @Auth.UserName
                </NavLink>
                <a href="#" class="text-white text-decoration-none small"
                   @onclick="Logout" @onclick:preventDefault>
                    <i class="bi bi-box-arrow-right"></i> Sair
                </a>
            }
            else
            {
                <NavLink href="/login" class="text-white text-decoration-none small">
                    <i class="bi bi-person-circle"></i> Entrar
                </NavLink>
                <NavLink href="/registrar" class="btn btn-outline-success btn-sm rounded-pill px-3">
                    Cadastrar-se
                </NavLink>
            }

            <AuthorizeView Roles="Admin">
                <Authorized>
                    <NavLink href="/admin" class="btn btn-warning btn-sm rounded-pill px-3 fw-bold">
                        <i class="bi bi-shield-lock-fill"></i> Admin
                    </NavLink>
                </Authorized>
            </AuthorizeView>
        </div>

        <!-- HAMBURGUER (só mobile) -->
        <button class="navbar-toggler d-md-none border-0" type="button"
                @onclick="ToggleMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

    </div>

    <!-- MENU MOBILE -->
    @if (menuAberto)
    {
        <div class="d-md-none bg-dark border-top border-secondary px-3 pb-3">

            <!-- BUSCA mobile -->
            <div class="pt-3 pb-2">
                <input type="text"
                       class="form-control form-control-sm rounded-pill"
                       placeholder="Buscar produtos..."
                       @bind="termoPesquisa"
                       @bind:event="oninput"
                       @onkeydown="OnKeyDown" />
            </div>

            <NavLink href="/" class="d-block text-white text-decoration-none py-2 border-bottom border-secondary" @onclick="FecharMenu">
                <i class="bi bi-house"></i> Início
            </NavLink>
            <NavLink href="/produtos" class="d-block text-white text-decoration-none py-2 border-bottom border-secondary" @onclick="FecharMenu">
                <i class="bi bi-grid"></i> Produtos
            </NavLink>
            <NavLink href="/carrinho" class="d-block text-white text-decoration-none py-2 border-bottom border-secondary" @onclick="FecharMenu">
                <i class="bi bi-cart"></i> Carrinho
                @if (Auth.IsAuthenticated && Carrinho.QuantidadeTotal > 0)
                {
                    <span class="badge bg-warning text-dark ms-1">@Carrinho.QuantidadeTotal</span>
                }
            </NavLink>

            @if (Auth.IsAuthenticated)
            {
                <NavLink href="/perfil" class="d-block text-white text-decoration-none py-2 border-bottom border-secondary" @onclick="FecharMenu">
                    <i class="bi bi-person"></i> @Auth.UserName
                </NavLink>
                <a href="#" class="d-block text-danger text-decoration-none py-2 border-bottom border-secondary"
                   @onclick="Logout" @onclick:preventDefault>
                    <i class="bi bi-box-arrow-right"></i> Sair
                </a>
            }
            else
            {
                <NavLink href="/login" class="d-block text-white text-decoration-none py-2 border-bottom border-secondary" @onclick="FecharMenu">
                    <i class="bi bi-person-circle"></i> Entrar
                </NavLink>
                <NavLink href="/registrar" class="d-block text-white text-decoration-none py-2 border-bottom border-secondary" @onclick="FecharMenu">
                    Cadastrar-se
                </NavLink>
            }

            <AuthorizeView Roles="Admin">
                <Authorized>
                    <NavLink href="/admin" class="d-block text-warning text-decoration-none py-2" @onclick="FecharMenu">
                        <i class="bi bi-shield-lock-fill"></i> Painel Admin
                    </NavLink>
                </Authorized>
            </AuthorizeView>
        </div>
    }
</nav>

<!-- CONTEÚDO PRINCIPAL -->
<div class="d-flex flex-column min-vh-100">
    <main class="container mt-4 flex-grow-1">
        @Body
    </main>

    <footer class="footer-tech mt-5">
        <div class="container py-5">
            <div class="row g-4">
                <div class="col-12 col-md-4">
                    <h4 class="footer-title">TechStore</h4>
                    <p class="footer-text">
                        Sua loja de tecnologia com os melhores preços,
                        qualidade e entrega rápida.
                    </p>
                </div>
                <div class="col-12 col-md-4">
                    <h5 class="footer-subtitle">Links Rápidos</h5>
                    <ul class="footer-links">
                        <li><NavLink href="/">Início</NavLink></li>
                        <li><NavLink href="/produtos">Produtos</NavLink></li>
                        <li><NavLink href="/carrinho">Carrinho</NavLink></li>
                    </ul>
                </div>
                <div class="col-12 col-md-4">
                    <h5 class="footer-subtitle">Contato</h5>
                    <p class="footer-text">📧 contato@techstore.com</p>
                    <p class="footer-text">📞 (31) 99999-9999</p>
                </div>
            </div>
        </div>
        <div class="footer-bottom text-center py-3">
            © 2026 TechStore - Engenheira de Software
            <a href="https://dalieneroque.github.io/Portifolio/" target="_blank"
               style="text-decoration: none; color: #0d6efd; font-weight: bold;">
                Daliene Roque
            </a>
        </div>
    </footer>
</div>

@code {
    [Inject] NavigationManager NavManager { get; set; }
    private string termoPesquisa = string.Empty;
    private bool menuAberto = false;

    private void ToggleMenu() => menuAberto = !menuAberto;
    private void FecharMenu() => menuAberto = false;

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(termoPesquisa))
        {
            menuAberto = false;
            NavManager.NavigateTo($"/produtos?search={termoPesquisa}");
        }
    }

    protected override void OnInitialized()
    {
        Auth.OnAuthChanged += StateHasChanged;
        Carrinho.OnCarrinhoChanged += StateHasChanged;
    }

    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Navigation.NavigateTo("/");
    }
}