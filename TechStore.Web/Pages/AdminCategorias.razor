@page "/admin/categorias/nova"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@using TechStore.Application.DTOs

@inject TechStore.Web.Services.CategoriaService CategoriaService
@inject NavigationManager Navigation

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">
                    <i class="bi bi-tags"></i> Nova Categoria
                </h5>
            </div>

            <div class="card-body">

                @if (!string.IsNullOrEmpty(erro))
                {
                    <div class="alert alert-danger">@erro</div>
                }

                @if (sucesso)
                {
                    <div class="alert alert-success">Categoria criada com sucesso!</div>
                }

                <div class="mb-3">
                    <label class="form-label fw-semibold">Nome da Categoria</label>
                    <input class="form-control"
                           @bind="categoria.Nome"
                           placeholder="Ex: Eletrônicos" />
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <button class="btn btn-outline-secondary" @onclick="Cancelar">
                        Cancelar
                    </button>
                    <button class="btn btn-success" @onclick="Salvar" disabled="@salvando">
                        <i class="bi bi-check-lg"></i>
                        @(salvando ? "Salvando..." : "Salvar Categoria")
                    </button>
                </div>

            </div>
        </div>
    </div>
</div>

@code {
    private CriarCategoriaDTO categoria = new();
    private bool salvando = false;
    private bool sucesso = false;
    private string? erro;

    private async Task Salvar()
    {
        try
        {
            salvando = true;
            erro = null;
            sucesso = false;

            await CategoriaService.CriarCategoriaAsync(categoria);

            sucesso = true;
            categoria = new(); // limpa o formulário
        }
        catch (Exception ex)
        {
            erro = ex.Message;
        }
        finally
        {
            salvando = false;
        }
    }

    private void Cancelar() => Navigation.NavigateTo("/admin");
}