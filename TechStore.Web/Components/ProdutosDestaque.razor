@using System.Linq
@using TechStore.Application.DTOs
@inject HttpClient Http
@inject TechStore.Web.Services.CarrinhoService CarrinhoService
@inject TechStore.Web.Services.AuthService AuthService
@inject NavigationManager Navigation

<div class="container mb-5">
    <h2 class="mb-4 text-center fw-bold">Produtos em Destaque</h2>
    <div class="row g-4">
        @if (produtos == null || !produtos.Any())
        {
            <p class="text-center">Carregando produtos...</p>
        }
        else
        {
            @foreach (var produto in produtos.Take(4))
            {
                <div class="col-12 col-sm-6 col-md-3">
                    <div class="card h-100 shadow-sm border-0 product-card">
                        <span class="badge bg-warning text-dark position-absolute m-2">
                            Destaque
                        </span>
                        <img src="@(string.IsNullOrEmpty(produto.ImagemUrl)
                                                                 ? "https://via.placeholder.com/300x200"
                                                                 : produto.ImagemUrl)"
                     class="card-img-top"
                     alt="@produto.Nome">
                <div class="card-body d-flex flex-column text-center">
                    <h5 class="card-title fw-semibold mb-2">@produto.Nome</h5>
                    <p class="text-muted small mb-1">@produto.Descricao</p>
                    <p class="text-success fw-bold fs-5 mb-3">
                        R$ @produto.Preco.ToString("N2")
                    </p>

                    @if (feedbacks.ContainsKey(produto.Id))
                            {
                                <div class="alert @(feedbacks[produto.Id] == "ok" ? "alert-success" : "alert-warning") py-1 small">
                                    @(feedbacks[produto.Id] == "ok" ? "✓ Adicionado!" : "Faça login para comprar")
                                </div>
                            }

                            <button class="btn btn-dark mt-auto w-100"
                                    @onclick="() => Comprar(produto.Id)"
                                    disabled="@carregando.Contains(produto.Id)">
                                @(carregando.Contains(produto.Id) ? "Adicionando..." : "Comprar")
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<ProdutoDTO> produtos = new();
    private HashSet<int> carregando = new();
    private Dictionary<int, string> feedbacks = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            produtos = await Http.GetFromJsonAsync<List<ProdutoDTO>>("api/produtos")
                ?? new List<ProdutoDTO>();
        }
        catch
        {
            produtos = new List<ProdutoDTO>();
        }
    }

    private async Task Comprar(int produtoId)
    {
        if (!AuthService.IsAuthenticated)
        {
            feedbacks[produtoId] = "login";
            StateHasChanged();
            await Task.Delay(2000);
            Navigation.NavigateTo("/login");
            return;
        }

        carregando.Add(produtoId);
        StateHasChanged();

        var sucesso = await CarrinhoService.AdicionarItemAsync(produtoId);

        carregando.Remove(produtoId);
        feedbacks[produtoId] = sucesso ? "ok" : "login";
        StateHasChanged();

        await Task.Delay(2000);
        feedbacks.Remove(produtoId);
        StateHasChanged();
    }
}